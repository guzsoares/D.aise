# Copie para `.env` e ajuste. O `.env` é gitignored.

# Habilita chamadas reais ao LLM (false = usa mockup)
USE_LLM=true

# Modo debug
DEBUG=false

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Conexão do backend com o banco. Aceita a forma curta postgresql:// (o app
# normaliza para o driver psycopg3 automaticamente).
#   - local:  postgresql://daise:daise@localhost:5432/daise
#   - docker: postgresql://daise:daise@db:5432/daise   (serviço `db` do compose)
DATABASE_URL=postgresql://daise:daise@localhost:5432/daise

# ─── Criptografia de credenciais ─────────────────────────────────────────────
# Chave-mestra (Fernet) usada para cifrar credenciais salvas no modo 'cloud'.
# Gere uma com:  python -m app.src.security.crypto
# Sem ela, só é possível salvar credenciais no modo 'local' (arquivo no host).
DAISE_SECRET_KEY=
